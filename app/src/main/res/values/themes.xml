<resources>
    <style name="Theme.AITimetable" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">#CDEEE3</item>
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorTertiary">@color/amber_accent</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:statusBarColor">@color/green_primary_dark</item>
        <item name="android:navigationBarColor">@color/screen_background</item>
    </style>

    <style name="Widget.AITimetable.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/green_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.AITimetable.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.AITimetable.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
    </style>
</resources>
